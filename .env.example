APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Set to false in production to prevent stack trace disclosure
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart-hrms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production (requires HTTPS)
SESSION_SECURE_COOKIE=false

# Comma-separated trusted proxy IPs, or * for all (only use * behind a known load balancer)
# TRUSTED_PROXIES=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD="your-16-char-app-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-gmail@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
# Route all employee credential emails to this inbox (synthetic data demo).
# Leave blank to send to each employee's own email instead.
MAIL_CREDENTIALS_RECIPIENT="your-gmail@gmail.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ZLINK_URL=https://zlink-open.minervaiot.com
ZLINK_APP_KEY=
ZLINK_APP_SECRET=
ZLINK_SIGNATURE_TOKEN=
ZLINK_ENCRYPTION_KEY=
ZLINK_DEFAULT_DEPARTMENT_ID=

ATTENDANCE_SHIFT_START=08:00
ATTENDANCE_GRACE_PERIOD_MINUTES=0

# Optional Python runtime overrides for the four core intelligent services.
# Set these when your Python executable lives outside the service-local .venv path.
# IWR_PYTHON_PATH=
# PPE_PYTHON_PATH=
# ATRE_PYTHON_PATH=
# FLATFAT_PYTHON_PATH=

VITE_APP_NAME="${APP_NAME}"
