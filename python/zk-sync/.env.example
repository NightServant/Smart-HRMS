# IP address of the ZK Teco device on your local network
ZK_DEVICE_IP=192.168.1.100

# TCP port (default 4370 for ZK Teco)
ZK_DEVICE_PORT=4370

# Device serial number — must match what's registered in HRMS admin
ZK_DEVICE_SN=JUS3251600158

# Your Railway Laravel API base URL (no trailing slash)
LARAVEL_URL=https://your-app.up.railway.app

# API key from HRMS Admin → System Settings → Devices
ZK_API_KEY=c6b1b55849cc4ad3c622b4b25cbec135b1c327d50d38c68cf642efa22c389458
