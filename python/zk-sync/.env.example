# ZKBio Zlink portal credentials
ZLINK_USERNAME=your-email@example.com
ZLINK_PASSWORD=your-password

# Device identifiers (found in Zlink → Device Center → Device Details)
ZLINK_DEVICE_ID=your-device-id-hex
ZLINK_DEVICE_SN=your-device-serial-number

# Your Railway Laravel API base URL (no trailing slash)
LARAVEL_URL=https://your-app.up.railway.app

# API key from HRMS Admin → System Settings → Devices
ZK_API_KEY=your-64-char-hex-api-key
